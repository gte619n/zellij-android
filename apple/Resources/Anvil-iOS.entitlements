<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- APNs environment. "development" for Xcode debug builds; flip to "production" for
         TestFlight / App Store. Requires the Push Notifications capability on the App ID. -->
    <key>aps-environment</key>
    <string>development</string>
</dict>
</plist>
