# Anvil daemon environment — see arch §3 (auth & billing constraint).
#
# Generate the OAuth token with:  claude setup-token
# This authenticates Claude Code against your Max subscription (NOT metered API billing).
CLAUDE_CODE_OAUTH_TOKEN=

# ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN MUST NOT be set.
# They outrank the OAuth token in Claude Code's auth precedence and would silently
# switch billing to metered pay-per-token. The daemon refuses to start if either is set.

# Optional overrides:
# ANVIL_PORT=7701
# ANVIL_STATE_DIR=~/.anvil
# ANVIL_BUDGET_WARN=0.8
# ANVIL_BUDGET_SOFTSTOP=0.95
