{
  "name": "anvild",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Anvil daemon — supervises Claude Code sessions and serves the Anvil protocol over Tailscale.",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "build:web": "bun run web/build.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.3",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.183",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.11",
    "jsdom": "^29.1.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.15.0",
    "shiki": "^4.2.0"
  }
}
